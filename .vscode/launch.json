{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-q",
        "-s"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/quality-gate/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug quality_gate.doctor",
      "type": "debugpy",
      "request": "launch",
      "module": "quality_gate.doctor",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/quality-gate/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
