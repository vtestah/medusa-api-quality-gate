{
  "name": "medusa-storefront-e2e",
  "private": true,
  "description": "Playwright (TypeScript) UI E2E against the localized RU/US Medusa storefront.",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:ru": "playwright test --project=ru",
    "test:us": "playwright test --project=us",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
