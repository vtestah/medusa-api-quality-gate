{
  "name": "ecom-quality-gate",
  "private": true,
  "scripts": {
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f medusa",
    "docker:logs:storefront": "docker compose logs -f storefront",
    "docker:seed-demo": "docker compose exec -T medusa pnpm seed && pnpm docker:sync-key && docker compose up -d storefront",
    "docker:sync-key": "./scripts/sync-publishable-key.sh",
    "storefront:dev": "pnpm --dir apps/storefront dev",
    "storefront:lint": "pnpm --dir apps/storefront lint"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
